# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Local:
MONGO_URI=mongodb+srv://priyanshu_mentor:Mentor%40csit@mentor-diary-cluster.wnimsxq.mongodb.net/?appName=mentor-diary-cluster

# MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.xxxxx.mongodb.net/csit_mentor_diary?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=59aaf7ab47758c358fee99b244b602f38e1381188fb4cfef4f85d72380028021
JWT_EXPIRES_IN=24h

# ─── Admin Registration Key ───────────────────────────────────────────────────
# Required when registering a user with role=admin via the /api/auth/register endpoint.
# Change this to something strong and keep it secret.
ADMIN_REGISTRATION_KEY=Admin@csit

# --- Mentor Registration Key --------------------------------------------------
# Required when registering a user with role=mentor via the /api/auth/register endpoint.
# Change this to something strong and keep it secret.
MENTOR_REGISTRATION_KEY=Mentor@csit

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
# Set to "production" in prod — enables HTTPS-only cookies, disables dev logging,
# and makes Express serve public/mentor-diary.html at the root URL.
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
